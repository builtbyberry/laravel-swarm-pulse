{
    "name": "builtbyberry/laravel-swarm-pulse",
    "description": "Laravel Pulse integration for Laravel Swarm — recorders and dashboard cards for swarm runs, steps, memory, and audit outbox observability.",
    "keywords": ["laravel", "ai", "agents", "swarm", "pulse", "observability"],
    "homepage": "https://swarm.builtbyberry.com",
    "support": {
        "docs": "https://swarm.builtbyberry.com",
        "issues": "https://github.com/builtbyberry/laravel-swarm-pulse/issues",
        "source": "https://github.com/builtbyberry/laravel-swarm-pulse"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Berry",
            "email": "daniel@jstreetdigital.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "builtbyberry/laravel-swarm": "^0.22 || ^0.23",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0",
        "laravel/pulse": "^1.7",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "builtbyberry/laravel-swarm-installer-testkit": "^0.1.0",
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarmPulse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BuiltByBerry\\LaravelSwarmPulse\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "BuiltByBerry\\LaravelSwarmPulse\\PulseServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G --no-progress",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/pest tests/Feature tests/Installer"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
